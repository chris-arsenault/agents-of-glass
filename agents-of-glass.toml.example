# Agents of Glass — non-secret config
# Copy to `agents-of-glass.toml` (or `agents-of-glass.local.toml`) and adjust.
# Never commit secrets here. Inject via the operator's secrets manager.

[postgres]
# host/port/database/user for the LAN Postgres.
# Password injected by the secrets manager via env: AOG_PG_PASSWORD (or PGPASSWORD).
# Any field can be omitted; libpq env vars (PGHOST, PGPORT, PGDATABASE, PGUSER)
# are read as fallbacks.
host = "192.168.66.3"
port = 5432
database = "agents_of_glass"
user = "agents_of_glass_app"

[falkordb]
# host/port for the LAN FalkorDB. Note port 16379 (not the default 6379).
# Password (if set on the FalkorDB instance) injected via env:
# AOG_FALKOR_PASSWORD or REDIS_PASSWORD.
host = "192.168.66.3"
port = 16379
graph = "agents_of_glass"

[embedding]
# OpenAI-compatible local embedding service.
url = "http://192.168.66.3:5361/v1/embeddings"
model = "nomic-ai/nomic-embed-text-v1.5"
provider = "openai-compatible"
timeout_seconds = 30
batch_size = 32
document_prefix = "search_document: "
query_prefix = "search_query: "

[lore]
# read-only path to the world bible
path = "../the-glass-frontier-lore"

[agent]
# Orchestrator provider policy. `mixed-codex` means Mara plus the selected
# players below use Codex across all of their turns; everyone else uses Claude.
# Override per run with `aog campaign run --use-codex` or `--use-claude`.
provider = "claude"
# Players routed to Codex when provider = "mixed-codex". Default mixed table is
# the first two players: tev and sumi.
codex_players = ["tev", "sumi"]
# When true, active-play player turns use the character branch: no
# player-persona file, no player notes/journal/drafts, and character-framed
# methodologies/instructions. Override per run with
# `--skip-player-persona` or `--no-skip-player-persona`.
skip_player_persona = false

[paths]
templates = "templates"          # authored content; stable input, copied to campaigns/<id>/ at bootstrap
campaigns = "campaigns"          # per-campaign live workspaces; created by `aog campaign bootstrap`
sessions = "sessions"            # runtime per-session state (legacy path; transitional)
ephemeral_cwd = ".glass-cwd"     # stable per-actor agent CWDs; not committed

[claude]
# claude-p invocation tunables
model = "opus"
# One Claude Code session id is tracked per actor. When true, the orchestrator
# creates the first attached invocation with `--session-id` and resumes later
# attached invocations with `--resume`; when false, ids are still tracked but
# not attached to invocations. Override for an operator run with `aog campaign
# run --use-session-id` or `--no-use-session-id`.
use_session_id = false
# Per-turn wall-clock cap. The DM during campaign-planning reads the
# methodology, persona, world bible, does web searches, and writes 8+ files
# per invocation. 300s was too short. 3600s (60 min) is the default;
# tighten if you want faster failure on hung agents.
turn_timeout_seconds = 3600

[caps]
# v0 closure — hard limits to guarantee sessions terminate
session_max_turns = 200
mode_default_max_turns = 12
mode_scene_play_max_turns = 120
mode_action_max_turns = 120

[orchestrator]
# Minimum wall-clock duration for each completed turn. If a turn finishes
# faster, the orchestrator waits before starting the next one. Set to 0 for no
# pacing delay.
turn_minimum_seconds = 600
