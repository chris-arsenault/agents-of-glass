#!/usr/bin/env bash
# aog-permset — root-privileged helper used by the orchestrator to set
# ownership and modes on a freshly-created campaign workspace or a per-turn
# ephemeral CWD.
#
# Installed by scripts/provision-agents.sh to /usr/local/bin/aog-permset.
# Invoked via sudo by the orchestrator (sudoers entry permits NOPASSWD).
#
# Subcommands:
#   campaign <campaign-dir>         apply campaign workspace permissions
#   clean-workspace <campaign-dir>  rm -rf the campaign workspace (root)
#
# All paths are validated to be under expected roots before any chown/chmod
# fires.

set -euo pipefail

OPERATOR="${SUDO_USER:-}"
if [[ -z "$OPERATOR" ]]; then
    echo "aog-permset: SUDO_USER not set; refusing to run." >&2
    exit 1
fi
OPERATOR_GROUP="$(id -gn "$OPERATOR")"

SHARED_GROUP="aog-agents"
PLAYER_IDS=(tev sumi renno kit)

usage() {
    cat <<EOF
Usage: $0 campaign <campaign-dir>
       $0 clean-workspace <campaign-dir>
EOF
    exit 1
}

# --- helpers ---

assert_path_safe() {
    # Forbid ".." and require the path to be absolute and exist.
    local path="$1"
    case "$path" in
        */../*|*/..) echo "aog-permset: path contains '..': $path" >&2; exit 1 ;;
        /*) ;;
        *) echo "aog-permset: path must be absolute: $path" >&2; exit 1 ;;
    esac
    if [[ ! -e "$path" ]]; then
        echo "aog-permset: path does not exist: $path" >&2
        exit 1
    fi
}

assert_player_id() {
    local id="$1"
    for known in "${PLAYER_IDS[@]}"; do
        if [[ "$id" == "$known" ]]; then return 0; fi
    done
    echo "aog-permset: unknown player id: $id" >&2
    exit 1
}

# Apply ownership + mode to a path, treating dirs and files appropriately.
# Args: owner group dir-mode file-mode path [path ...]
apply_perms() {
    local owner="$1" group="$2" dirmode="$3" filemode="$4"
    shift 4
    for target in "$@"; do
        if [[ ! -e "$target" ]]; then continue; fi
        chown "$owner:$group" "$target"
        if [[ -d "$target" ]]; then
            chmod "$dirmode" "$target"
        else
            chmod "$filemode" "$target"
        fi
    done
}

apply_perms_recursive() {
    local owner="$1" group="$2" dirmode="$3" filemode="$4"
    shift 4
    for target in "$@"; do
        if [[ ! -e "$target" ]]; then continue; fi
        chown -R "$owner:$group" "$target"
        find "$target" -type d -exec chmod "$dirmode" {} +
        find "$target" -type f -exec chmod "$filemode" {} +
    done
}

# --- subcommands ---

cmd_campaign() {
    local campaign_dir="${1:-}"
    [[ -z "$campaign_dir" ]] && usage
    assert_path_safe "$campaign_dir"

    # Top-level state.json and context.md
    apply_perms "$OPERATOR" "$SHARED_GROUP" 0750 0640 \
        "$campaign_dir/state.json" \
        "$campaign_dir/context.md"

    # DM-only tree
    apply_perms_recursive "$OPERATOR" "$OPERATOR_GROUP" 0700 0600 \
        "$campaign_dir/dm"

    # Shared content — all agents read, operator writes
    apply_perms_recursive "$OPERATOR" "$SHARED_GROUP" 2750 0640 \
        "$campaign_dir/shared" \
        "$campaign_dir/methodologies"

    # Per-player private dirs and files
    for pid in "${PLAYER_IDS[@]}"; do
        local pdir="$campaign_dir/players/$pid"
        local puser="aog-$pid"
        if [[ ! -d "$pdir" ]]; then continue; fi

        # Private subdirs: owner = player, group = player's own group, setgid
        # so files created inside inherit the player-private group.
        apply_perms_recursive "$puser" "$puser" 2750 0640 \
            "$pdir/journal" \
            "$pdir/drafts" \
            "$pdir/notes" \
            "$pdir/inbox" \
            "$pdir/secrets"

        # turns/: operator owns so the orchestrator can always mkdir
        # per-turn subdirs without depending on group membership; group
        # is the player's primary group, setgid so files inherit it.
        # Mode 2770 + orchestrator umask 002 -> child subdirs are 2775
        # (group write), so the player can write their own out.md.
        if [[ -d "$pdir/turns" ]]; then
            apply_perms_recursive "$OPERATOR" "$puser" 2770 0660 "$pdir/turns"
        fi

        # Public subdir: owner = player, group = aog-agents, setgid so files
        # created inside inherit the shared group and become party-readable.
        # This is where intro.md, relationships.md, the cached character.md
        # display, and any other party-visible artifacts live.
        if [[ -d "$pdir/public" ]]; then
            apply_perms_recursive "$puser" "$SHARED_GROUP" 2750 0640 "$pdir/public"
        fi

        for f in persona.md scratchpad.md; do
            if [[ -f "$pdir/$f" ]]; then
                apply_perms "$puser" "$puser" 0640 0640 "$pdir/$f"
            fi
        done

        # Player root dir: owner = OPERATOR, group = aog-agents, mode 0750
        # (NO setgid). Operator-owned so the orchestrator (running as the
        # operator) can always traverse it, even from a shell that hasn't
        # picked up aog-agents in its effective groups yet (group lag from
        # not having logged out + back in after provisioning). Group rx for
        # other agents (all in aog-agents) so they can cd into public/.
        # The player's own write access lives inside the provisioned
        # subdirs (drafts/, journal/, notes/, inbox/, secrets/, public/,
        # turns/), which are explicitly chowned to the player above.
        # NOTE: explicit `g-s` because on ZFS+nfs4acl filesystems chmod
        # 0750 does not clear the setgid bit.
        chown "$OPERATOR:$SHARED_GROUP" "$pdir"
        chmod g-s "$pdir"
        chmod 0750 "$pdir"
    done

    # The players/ container itself: dev:aog-agents 2750 (all agents can
    # traverse, only operator can change the player roster)
    if [[ -d "$campaign_dir/players" ]]; then
        chown "$OPERATOR:$SHARED_GROUP" "$campaign_dir/players"
        chmod 2750 "$campaign_dir/players"
    fi

    # arcs/ — populated lazily; default ownership for now
    if [[ -d "$campaign_dir/arcs" ]]; then
        chown "$OPERATOR:$SHARED_GROUP" "$campaign_dir/arcs"
        chmod 2750 "$campaign_dir/arcs"
    fi

    # The campaign root itself
    chown "$OPERATOR:$SHARED_GROUP" "$campaign_dir"
    chmod 2750 "$campaign_dir"
}

cmd_clean_workspace() {
    local campaign_dir="${1:-}"
    [[ -z "$campaign_dir" ]] && usage
    assert_path_safe "$campaign_dir"

    # Refuse to remove anything outside a `campaigns/` directory — be
    # paranoid about misuse since this runs as root.
    case "$campaign_dir" in
        */campaigns/*) ;;
        *) echo "aog-permset: clean-workspace path must contain '/campaigns/'; got $campaign_dir" >&2; exit 1 ;;
    esac
    if [[ ! -d "$campaign_dir" ]]; then
        echo "aog-permset: not a directory: $campaign_dir" >&2
        exit 1
    fi
    rm -rf -- "$campaign_dir"
}

case "${1:-}" in
    campaign)         shift; cmd_campaign "$@" ;;
    clean-workspace)  shift; cmd_clean_workspace "$@" ;;
    *)                usage ;;
esac
