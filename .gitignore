# Python
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Frontend
frontend/node_modules/
frontend/dist/
frontend/coverage/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Project-specific
# local campaign workspaces should remain local-only
campaigns/
# local campaign runtime secrets/debug exports
campaigns/**/.glass-grants.json
campaigns/.checkpoints/
campaigns/**/agent-debug.json
# ephemeral per-turn agent CWDs
.glass-cwd/
# local machine secrets for operator-owned processes
.env
.env.*
# local rollback snapshots may include campaign state/grants
.reset-backups/
# local pasted/debug context
.sulion-paste/
# local config overrides (e.g. agents-of-glass.local.toml)
*.local.toml

# Terraform
**/.terraform/
*.tfstate
*.tfstate.*
.terraform.lock.hcl

# OS
.DS_Store
Thumbs.db
